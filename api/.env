# API 服务配置示例文件
# 复制此文件为 .env 并填入实际值

# ==================== 基础配置 ====================

# 调试模式 (True/False)
API_DEBUG=False

# 服务监听地址
API_HOST=0.0.0.0

# 服务端口
API_PORT=5000

# ==================== 文件上传配置 ====================

# 上传文件临时目录
UPLOAD_FOLDER=/tmp/test-case-api

# 最大上传文件大小 (字节)，默认 16MB
MAX_CONTENT_LENGTH=16777216

# ==================== AI 配置 ====================

# LLM 提供商 (qwen / openai)
LLM_PROVIDER=qwen

# LLM 模型名称
LLM_MODEL=qwen-max

# API Key (必需配置其中一个)
# 通义千问
QWEN_API_KEY=your_qwen_api_key_here

# OpenAI (备选)
# OPENAI_API_KEY=your_openai_api_key_here

# ==================== 生成器配置 ====================

# 最大输入 token 数
MAX_INPUT_TOKENS=8000

# 生成策略 (auto / full / by_branch / by_leaf)
GENERATION_STRATEGY=auto

# ==================== 日志配置 ====================

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
